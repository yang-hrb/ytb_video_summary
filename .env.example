# OpenRouter API
OPENROUTER_API_KEY=your_api_key_here
# Default model when MODEL_PRIORITY_* all fail
OPENROUTER_MODEL=openrouter/free
MODEL_PRIORITY_1=tngtech/deepseek-r1t2-chimera:free
MODEL_PRIORITY_2=stepfun/step-3.5-flash:free
MODEL_PRIORITY_3=arcee-ai/trinity-large-preview:free
MODEL_FALLBACK=openai/gpt-4o-mini  # Fallback model

# GitHub Integration (Optional)
# If not set, files will only be saved locally
# To use: Set up a GitHub Personal Access Token with 'repo' permissions
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=username/repository_name
GITHUB_BRANCH=main

# Whisper 配置
WHISPER_MODEL=base       # tiny/base/small/medium/large
WHISPER_LANGUAGE=auto    # zh/en/auto (matches settings.py default)

# 音频配置
AUDIO_QUALITY=64  # 32/64/96/128 kbps
AUDIO_FORMAT=mp3  # mp3/opus
KEEP_AUDIO=false  # true/false

# 摘要输出语言配置 (Summary Output Language)
# Options: 'zh' for Chinese (default), 'en' for English
# Note: This controls AI-generated summaries/reports language
# Whisper transcription language is controlled by WHISPER_LANGUAGE
SUMMARY_LANGUAGE=zh  # zh/en

# FFmpeg 配置（可选，程序会自动检测）
# FFMPEG_LOCATION=/opt/homebrew/bin  # macOS Homebrew
# FFMPEG_LOCATION=/usr/local/bin     # Linux/macOS
# FFMPEG_LOCATION=C:\ffmpeg\bin      # Windows

# 浏览器配置（会员视频）
BROWSER_TYPE=chrome  # chrome/firefox/edge/safari
USE_COOKIES_FILE=false  # true 时使用 cookies.txt

# 输出配置
OUTPUT_DIR=output
TEMP_DIR=temp
