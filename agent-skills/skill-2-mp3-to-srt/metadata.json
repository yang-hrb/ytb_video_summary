{
  "name": "skill-2-mp3-to-srt",
  "version": "0.1.0",
  "description": "使用 Whisper 将 MP3 转写为 SRT 字幕文件。",
  "compatible_runtimes": ["claude-code", "open-code"],
  "entrypoint": "scripts/mp3_to_srt.py",
  "inputs": {
    "mp3_path": "MP3 文件路径",
    "language": "转写语言（zh/en/auto）",
    "output_dir": "输出目录（默认 output/transcripts）"
  },
  "outputs": {
    "srt_path": "生成的 SRT 文件路径",
    "detected_language": "Whisper 识别语言"
  },
  "requirements": {
    "python": ">=3.9",
    "system": ["ffmpeg"],
    "python_packages": ["openai-whisper", "python-dotenv"],
    "env": ["WHISPER_MODEL", "WHISPER_LANGUAGE"]
  },
  "tags": ["whisper", "transcription", "srt", "mp3"]
}
